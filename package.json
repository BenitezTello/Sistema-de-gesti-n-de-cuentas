  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n UI,APP,WA -c cyan,green,yellow \"vite\" \"cross-env PORT=3002 node server/index.js\" \"node server/wa.js\"",
    "dev:ui": "vite",
    "dev:app": "cross-env PORT=3002 node server/index.js",
    "dev:wa": "node server/wa.js",
    "build": "vite build",
    "start": "node server/index.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
