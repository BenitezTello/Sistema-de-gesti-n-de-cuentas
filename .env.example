# Copia este archivo a .env y rellena con tus valores reales
# El .env NUNCA va al repositorio (está en .gitignore)

# Clave JWT — genera una con: node -e "require('crypto').randomBytes(48).toString('base64') |> console.log"
JWT_SECRET=reemplaza-con-clave-aleatoria-larga

# Clave de cifrado AES-256 — debe ser exactamente 64 caracteres hex (32 bytes)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=reemplaza-con-64-caracteres-hex
